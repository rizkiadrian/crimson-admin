{
  // Jadikan Prettier sebagai formatter utama
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Aktifkan format otomatis setiap kali file di-save
  "editor.formatOnSave": true,

  // Aktifkan auto-fix ESLint saat save
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // Pengaturan spesifik per bahasa agar dipastikan menggunakan Prettier
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
