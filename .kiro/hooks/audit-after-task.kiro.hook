{
  "enabled": true,
  "name": "NPM Audit After Task",
  "description": "Runs npm audit when manually triggered to check for vulnerabilities.",
  "version": "2",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "cd lingkar-crm && npm audit",
    "timeout": 30
  }
}
